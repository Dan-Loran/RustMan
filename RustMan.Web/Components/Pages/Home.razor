@page "/"
@using RustMan.Presentation.Modules.ConsoleStream
@using RustMan.Web.Modules.ConsoleStream.Components
@inject ConsoleStreamPresentationService ConsolePresentationService

<PageTitle>Home</PageTitle>

<section class="workspace">
    <header class="workspace__header">
        <p class="workspace__eyebrow">Live Operations</p>
        <h1>ROTEN</h1>
        <p class="workspace__description">Console stream from the running server.</p>
    </header>

    <ConsoleStreamDisplay PresentationService="ConsolePresentationService" />
</section>

<style>
    .workspace {
        display: grid;
        gap: 1rem;
        padding: 1rem 0;
    }

    .workspace__header h1 {
        margin: 0;
    }

    .workspace__eyebrow {
        margin: 0 0 0.2rem;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #4c6b8a;
    }

    .workspace__description {
        margin: 0.35rem 0 0;
        color: #5f7183;
    }
</style>
