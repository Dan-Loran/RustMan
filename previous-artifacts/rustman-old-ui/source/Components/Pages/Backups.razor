@page "/settings/backups"

@using RustMan.Models
@using RustMan.Services

@inject InstanceBackupService InstanceBackupService

<PageTitle>Backup Inventory</PageTitle>

<section class="page-header">
    <div>
        <p class="page-eyebrow">Settings</p>
        <h1>Backup Inventory</h1>
        <p class="page-copy">
            Review all saved backups, restore them as clean replacements, or remove them when they are no longer needed.
        </p>
    </div>

    <div class="page-actions">
        <a class="secondary-link" href="/settings">Back to Settings</a>
    </div>
</section>

<section class="surface-card backup-shell">
    <h2>All Backups</h2>
    <p>
        Backups stay available even when the original instance has been deleted.
    </p>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <p class="@($"backup-status {(_isError ? "is-error" : "is-success")}")">@_statusMessage</p>
    }

    @if (_backups.Count == 0)
    {
        <p class="backup-empty">No backups are available yet. Create a backup from an instance workspace to populate this inventory.</p>
    }
    else
    {
        <div class="backup-list">
            @foreach (var backup in _backups)
            {
                <article class="backup-item">
                    <div class="backup-item-header">
                        <div>
                            <h3>@backup.SourceName</h3>
                            <p class="backup-meta">
                                Source slug: <strong>@backup.SourceSlug</strong><br />
                                Created: @backup.CreatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                            </p>
                        </div>

                        @if (backup.SourceInstanceExists)
                        {
                            <span class="backup-badge active">Instance present</span>
                        }
                        else
                        {
                            <span class="backup-badge missing">Instance missing</span>
                        }
                    </div>

                    <div class="backup-actions">
                        <button type="button"
                                class="secondary-button"
                                @onclick="() => ConfirmRestore(backup)"
                                disabled="@(_isRestoring || _isDeleting)">
                            Restore
                        </button>
                        <button type="button"
                                class="danger-button"
                                @onclick="() => ConfirmDelete(backup)"
                                disabled="@(_isRestoring || _isDeleting)">
                            Delete
                        </button>
                    </div>

                    @if (_pendingRestoreBackup?.Path == backup.Path)
                    {
                        <div class="backup-confirmation">
                            <p>
                                Restore <strong>@backup.Name</strong> for <strong>@backup.SourceSlug</strong>? This will replace the current instance state for that slug.
                            </p>
                            <div class="backup-confirmation-actions">
                                <button type="button"
                                        class="secondary-button"
                                        @onclick="() => RestoreBackupAsync(backup)"
                                        disabled="@(_isRestoring || _isDeleting)">
                                    @(_isRestoring ? "Restoring..." : "Confirm Restore")
                                </button>
                                <button type="button"
                                        class="secondary-link shell-button"
                                        @onclick="CancelAction"
                                        disabled="@(_isRestoring || _isDeleting)">
                                    Cancel
                                </button>
                            </div>
                        </div>
                    }

                    @if (_pendingDeleteBackup?.Path == backup.Path)
                    {
                        <div class="backup-confirmation delete">
                            <p>Delete backup <strong>@backup.Name</strong> for <strong>@backup.SourceSlug</strong>?</p>
                            <div class="backup-confirmation-actions">
                                <button type="button"
                                        class="danger-button"
                                        @onclick="() => DeleteBackupAsync(backup)"
                                        disabled="@(_isRestoring || _isDeleting)">
                                    @(_isDeleting ? "Deleting..." : "Confirm Delete")
                                </button>
                                <button type="button"
                                        class="secondary-link shell-button"
                                        @onclick="CancelAction"
                                        disabled="@(_isRestoring || _isDeleting)">
                                    Cancel
                                </button>
                            </div>
                        </div>
                    }
                </article>
            }
        </div>
    }
</section>

@code {
    private List<InstanceBackupRecord> _backups = [];
    private InstanceBackupRecord? _pendingRestoreBackup;
    private InstanceBackupRecord? _pendingDeleteBackup;
    private string? _statusMessage;
    private bool _isError;
    private bool _isRestoring;
    private bool _isDeleting;

    protected override async Task OnInitializedAsync()
    {
        await LoadBackupsAsync();
    }

    private async Task LoadBackupsAsync()
    {
        _backups = await InstanceBackupService.GetAllBackupsAsync();
    }

    private void ConfirmRestore(InstanceBackupRecord backup)
    {
        _statusMessage = null;
        _isError = false;
        _pendingDeleteBackup = null;
        _pendingRestoreBackup = backup;
    }

    private void ConfirmDelete(InstanceBackupRecord backup)
    {
        _statusMessage = null;
        _isError = false;
        _pendingRestoreBackup = null;
        _pendingDeleteBackup = backup;
    }

    private void CancelAction()
    {
        _pendingRestoreBackup = null;
        _pendingDeleteBackup = null;
    }

    private async Task RestoreBackupAsync(InstanceBackupRecord backup)
    {
        _isRestoring = true;
        _statusMessage = null;
        _isError = false;

        try
        {
            await InstanceBackupService.RestoreBackupAsync(backup.SourceSlug, backup.Name);
            _statusMessage = $"Restored backup '{backup.Name}' to slug '{backup.SourceSlug}'.";
            CancelAction();
            await LoadBackupsAsync();
        }
        catch (Exception ex)
        {
            _isError = true;
            _statusMessage = ex.Message;
        }
        finally
        {
            _isRestoring = false;
        }
    }

    private async Task DeleteBackupAsync(InstanceBackupRecord backup)
    {
        _isDeleting = true;
        _statusMessage = null;
        _isError = false;

        try
        {
            await InstanceBackupService.DeleteBackupAsync(backup.SourceSlug, backup.Name);
            _statusMessage = $"Deleted backup '{backup.Name}'.";
            CancelAction();
            await LoadBackupsAsync();
        }
        catch (Exception ex)
        {
            _isError = true;
            _statusMessage = ex.Message;
        }
        finally
        {
            _isDeleting = false;
        }
    }
}
