@page "/settings/about"

@using RustMan.Models
@using RustMan.Services

@inject HostAboutService HostAboutService

<PageTitle>About RustMan</PageTitle>

<section class="page-header">
    <div>
        <p class="page-eyebrow">Settings</p>
        <h1>About RustMan</h1>
        <p class="page-copy">
            Review the installed application version and the host-level paths RustMan uses on this machine.
        </p>
    </div>

    <div class="page-actions">
        <a class="secondary-link" href="/settings">Back to Settings</a>
    </div>
</section>

<div class="about-grid">
    <section class="surface-card">
        <div class="settings-eyebrow">Application</div>
        <h2>RustMan</h2>

        <dl class="about-list">
            <div>
                <dt>Version</dt>
                <dd>@_info.ApplicationVersion</dd>
            </div>
            <div>
                <dt>Machine</dt>
                <dd>@_info.MachineName</dd>
            </div>
            <div>
                <dt>Operating system</dt>
                <dd>@_info.OperatingSystem</dd>
            </div>
        </dl>
    </section>

    <section class="surface-card">
        <div class="settings-eyebrow">Paths</div>
        <h2>Install Layout</h2>

        <dl class="about-list">
            <div>
                <dt>Application root</dt>
                <dd>@_info.ContentRootPath</dd>
            </div>
            <div>
                <dt>Runtime root</dt>
                <dd>@_info.RuntimeRootPath</dd>
            </div>
            <div>
                <dt>SteamCMD path</dt>
                <dd>@_info.SteamCmdPath</dd>
            </div>
            <div>
                <dt>Rust runtime path</dt>
                <dd>@_info.RustRuntimePath</dd>
            </div>
        </dl>
    </section>

    <section class="surface-card">
        <div class="settings-eyebrow">Shared Runtime</div>
        <h2>Installed Components</h2>

        <div class="about-badges">
            <span class="about-badge @(_info.SteamCmdPresent ? "present" : "missing")">
                SteamCMD: @(_info.SteamCmdPresent ? "Present" : "Missing")
            </span>
            <span class="about-badge @(_info.RustRuntimePresent ? "present" : "missing")">
                Rust runtime: @(_info.RustRuntimePresent ? "Present" : "Missing")
            </span>
        </div>
    </section>
</div>

@code {
    private HostAboutInfo _info = new();

    protected override void OnInitialized()
    {
        _info = HostAboutService.GetInfo();
    }
}
