@page "/instances/create"
@page "/instances/{Slug}/edit"

@using RustMan.Models
@using RustMan.Services
@using RustMan.State

@inject InstanceEditState State
@inject ServerPropertyCatalogService PropertyCatalog
@inject InstanceDraftValidationService DraftValidator
@inject InstanceService InstanceService
@inject InstanceCreationService InstanceCreationService
@inject InstanceUpdateService InstanceUpdateService
@inject NavigationManager Navigation

<PageTitle>@PageTitleText</PageTitle>

<section class="create-shell">
    <header class="page-header">
        <div>
            <p class="page-eyebrow">Instance Editor</p>
            <h1>@HeadingText</h1>
            <p class="page-copy">
                @PageCopyText
            </p>
        </div>

        <div class="page-actions">
            <a class="secondary-link" href="/instances">Back to Instances</a>
            <button type="button" class="secondary-link shell-button" @onclick="ResetDraft" disabled="@(_isSaving)">Reset Draft</button>
            <button type="button" class="primary-link shell-button" @onclick="SaveInstanceAsync" disabled="@(_isSaving)">
                @(_isSaving ? "Saving..." : SaveButtonText)
            </button>
        </div>
    </header>

    @if (_errors.Count > 0)
    {
        <section class="surface-card validation-card">
            <h2>Resolve These Issues</h2>
            <ul>
                @foreach (var error in _errors)
                {
                    <li>@error</li>
                }
            </ul>
        </section>
    }

    <div class="create-shell-grid">
        <div class="editor-column">
            <section class="surface-card">
                <div class="section-heading">
                    <div>
                        <p class="section-kicker">Standard Configuration</p>
                        <h2>Identity and Server Settings</h2>
                    </div>
                </div>

                <div class="form-grid">
                    <div class="form-field">
                        <label for="name">Instance Name</label>
                        <input id="name" @bind="State.Name" />
                    </div>

                    <div class="form-field">
                        <label for="slug">Slug</label>
                        <div class="inline-row">
                    <input id="slug" @bind="State.Slug" disabled="@(IsLocked(nameof(State.Slug)))" />
                            @if (!_isEditMode)
                            {
                                <button type="button" class="secondary-action" @onclick="GenerateSlugFromName">Generate</button>
                            }
                        </div>
                        <small>Slug becomes the permanent instance identity after creation.</small>
                    </div>

                    <div class="form-field field-full">
                        <label for="hostname">Server Hostname</label>
                        <input id="hostname" @bind="State.Hostname" />
                    </div>

                    <div class="form-field field-full">
                        <label for="description">Description</label>
                        <textarea id="description" rows="4" @bind="State.Description"></textarea>
                    </div>
                </div>
            </section>

            <section class="surface-card">
                <div class="section-heading">
                    <div>
                        <p class="section-kicker">Standard Configuration</p>
                        <h2>World and Network</h2>
                    </div>
                </div>

                <div class="form-grid">
                    <div class="form-field">
                        <label for="map-size">Map Size</label>
                    <input id="map-size" type="number" @bind="State.MapSize" disabled="@(IsLocked(nameof(State.MapSize)))" />
                    </div>

                    <div class="form-field">
                        <label for="map-seed">Map Seed</label>
                        <div class="inline-row">
                    <input id="map-seed" type="number" @bind="State.MapSeed" disabled="@(IsLocked(nameof(State.MapSeed)))" />
                            @if (!_isEditMode)
                            {
                                <button type="button" class="secondary-action" @onclick="GenerateRandomSeed">Random</button>
                            }
                        </div>
                    </div>

                    <div class="form-field">
                        <label for="max-players">Max Players</label>
                        <input id="max-players" type="number" @bind="State.MaxPlayers" />
                    </div>

                    <div class="form-field checkbox-field">
                        <label class="toggle-row">
                            <span>Auto Start</span>
                        </label>
                        <input type="checkbox" class="toggle-checkbox" @bind="State.AutoStart" />
                    </div>

                    <div class="form-field">
                        <label for="game-port">Game Port</label>
                        <input id="game-port" type="number" @bind="State.GamePort" />
                    </div>

                    <div class="form-field">
                        <label for="query-port">Query Port</label>
                        <input id="query-port" type="number" @bind="State.QueryPort" />
                    </div>

                    <div class="form-field">
                        <label for="rcon-port">RCON Port</label>
                        <input id="rcon-port" type="number" @bind="State.RconPort" />
                    </div>

                    <div class="form-field field-full">
                        <label for="rcon-password">RCON Password</label>
                        <input id="rcon-password" @bind="State.RconPassword" />
                    </div>
                </div>
            </section>

            <section class="surface-card advanced-surface">
                <div class="section-heading">
                    <div>
                        <p class="section-kicker">Advanced Configuration</p>
                        <h2>Common Advanced Settings</h2>
                        <p class="section-copy">
                            Frequently adjusted advanced overrides are surfaced here for quick access.
                        </p>
                    </div>
                </div>

                @if (_commonAdvancedGroups.Count == 0)
                {
                    <p class="empty-state">No common advanced prefixes are currently configured.</p>
                }
                else
                {
                    <div class="advanced-groups">
                        @foreach (var group in _commonAdvancedGroups)
                        {
                            <details class="property-group">
                                <summary>
                                    <span class="group-name">@group.Key</span>
                                    <span class="group-meta">@GetOverrideCount(group.Value) overridden</span>
                                </summary>

                                <div class="property-list">
                                    @foreach (var property in group.Value)
                                    {
                                        @RenderPropertyEditor(property)
                                    }
                                </div>
                            </details>
                        }
                    </div>
                }
            </section>

            <section class="surface-card advanced-surface">
                <div class="section-heading">
                    <div>
                        <p class="section-kicker">Advanced Configuration</p>
                        <h2>Additional Advanced Settings</h2>
                        <p class="section-copy">
                            The full advanced catalog remains grouped by Rust property prefix and draft-only until save.
                        </p>
                    </div>
                </div>

                @if (_groups.Count == 0)
                {
                    <p class="empty-state">No additional advanced property definitions were loaded.</p>
                }
                else
                {
                    <div class="advanced-groups">
                        @foreach (var group in _groups)
                        {
                            <details class="property-group">
                                <summary>
                                    <span class="group-name">@group.Key</span>
                                    <span class="group-meta">@GetOverrideCount(group.Value) overridden</span>
                                </summary>

                                <div class="property-list">
                                    @foreach (var property in group.Value)
                                    {
                                        @RenderPropertyEditor(property)
                                    }
                                </div>
                            </details>
                        }
                    </div>
                }
            </section>
        </div>

        <aside class="preview-column">
            <section class="surface-card preview-card">
                <div class="section-heading">
                    <div>
                        <p class="section-kicker">Generated Output</p>
                        <h2>Startup Preview</h2>
                        <p class="section-copy">
                            This preview reflects the current in-memory draft, including unsaved advanced overrides.
                        </p>
                    </div>
                </div>

                <pre>@State.StartupPreview</pre>
            </section>

            <section class="surface-card helper-card">
                <h2>Current Rules</h2>
                <ul>
                    <li>Slug is permanent after instance creation.</li>
                    <li>Map size and map seed are reserved for scheduled rotation workflows.</li>
                    <li>Advanced settings are stored as explicit overrides only.</li>
                    <li>The startup preview is always derived from draft state.</li>
                </ul>
            </section>
        </aside>
    </div>
</section>

@code {
    [Parameter]
    public string? Slug { get; set; }

    private List<ServerPropertyDefinition> _properties = new();
    private Dictionary<string, List<ServerPropertyDefinition>> _commonAdvancedGroups = new();
    private Dictionary<string, List<ServerPropertyDefinition>> _groups = new();
    private Dictionary<string, ServerPropertyDefinition> _propertyDefinitionsByKey = new();
    private List<string> _errors = new();
    private bool _isSaving;
    private bool _isEditMode;
    private InstanceRecord? _loadedInstance;
    private List<InstancePropertyValue> _loadedOverrides = new();

    private string PageTitleText => _isEditMode ? $"Edit {State.Name}" : "Create Instance";
    private string HeadingText => _isEditMode ? $"Edit {State.Name}" : "Create Instance";
    private string SaveButtonText => _isEditMode ? "Save Changes" : "Save Instance";
    private string PageCopyText => _isEditMode
        ? "Review the current instance configuration, update editable fields, and keep identity and world-generation settings stable."
        : "Configure the standard server fields first, then add advanced overrides only where the Rust defaults do not match your intended runtime behavior.";

    protected override async Task OnParametersSetAsync()
    {
        await EnsurePropertyCatalogLoadedAsync();
        await InitializeEditorStateAsync();
    }

    private async Task EnsurePropertyCatalogLoadedAsync()
    {
        if (_properties.Count > 0)
        {
            return;
        }

        _properties = await PropertyCatalog.GetAllAsync();
        _commonAdvancedGroups = _properties
            .Where(p => p.IsAdvanced && p.IsCommonAdvanced)
            .GroupBy(p => p.Prefix)
            .OrderBy(g => g.Key)
            .ToDictionary(g => g.Key, g => g.OrderBy(p => p.Key).ToList());

        _groups = _properties
            .Where(p => p.IsAdvanced && !p.IsCommonAdvanced)
            .GroupBy(p => p.Prefix)
            .OrderBy(g => g.Key)
            .ToDictionary(g => g.Key, g => g.OrderBy(p => p.Key).ToList());

        _propertyDefinitionsByKey = _properties.ToDictionary(p => p.Key, p => p);
    }

    private async Task InitializeEditorStateAsync()
    {
        _errors.Clear();

        if (string.IsNullOrWhiteSpace(Slug))
        {
            _isEditMode = false;
            _loadedInstance = null;
            _loadedOverrides = new();
            State.InitializeNewDefaults();
            return;
        }

        var instance = await InstanceService.GetBySlugAsync(Slug);

        if (instance is null)
        {
            _isEditMode = false;
            _loadedInstance = null;
            _loadedOverrides = new();
            _errors.Add($"Instance '{Slug}' was not found.");
            State.InitializeNewDefaults();
            return;
        }

        var overrides = await InstanceService.GetOverridesAsync(instance.Id);

        _isEditMode = true;
        _loadedInstance = instance;
        _loadedOverrides = overrides;
        State.LoadFrom(instance, overrides);
    }

    private RenderFragment RenderPropertyEditor(ServerPropertyDefinition property) => builder =>
    {
        var isOverridden = State.HasOverride(property.Key);
        var value = GetValue(property.Key);
        var placeholder = string.IsNullOrWhiteSpace(property.DefaultValue)
            ? null
            : $"Default: {property.DefaultValue}";
        var sequence = 0;

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", $"property-row {(isOverridden ? "overridden" : string.Empty)}".Trim());

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "property-header");

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "property-name");
        builder.OpenElement(sequence++, "strong");
        builder.AddContent(sequence++, property.DisplayName);
        builder.CloseElement();
        builder.CloseElement();

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "property-key");
        builder.AddContent(sequence++, property.Key);
        builder.CloseElement();

        builder.CloseElement();

        if (!string.IsNullOrWhiteSpace(property.Description))
        {
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "property-description");
            builder.AddContent(sequence++, property.Description);
            builder.CloseElement();
        }

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "property-editor");

        if (property.AllowedValues.Count > 0)
        {
            builder.OpenElement(sequence++, "select");
            builder.AddAttribute(sequence++, "value", value);
            builder.AddAttribute(sequence++, "onchange",
                EventCallback.Factory.CreateBinder<string?>(
                    this,
                    newValue => SetValue(property.Key, newValue),
                    value));

            builder.OpenElement(sequence++, "option");
            builder.AddAttribute(sequence++, "value", string.Empty);
            builder.AddContent(sequence++, placeholder ?? "Use Rust default");
            builder.CloseElement();

            foreach (var allowedValue in property.AllowedValues)
            {
                builder.OpenElement(sequence++, "option");
                builder.AddAttribute(sequence++, "value", allowedValue.Value);
                builder.AddContent(sequence++, allowedValue.DisplayName);
                builder.CloseElement();
            }

            builder.CloseElement();
        }
        else if (property.ValueType == "boolean")
        {
            builder.OpenElement(sequence++, "select");
            builder.AddAttribute(sequence++, "value", value);
            builder.AddAttribute(sequence++, "onchange",
                EventCallback.Factory.CreateBinder<string?>(
                    this,
                    newValue => SetBooleanValue(property.Key, newValue),
                    value));

            builder.OpenElement(sequence++, "option");
            builder.AddAttribute(sequence++, "value", string.Empty);
            builder.AddContent(sequence++, placeholder ?? "Use Rust default");
            builder.CloseElement();

            builder.OpenElement(sequence++, "option");
            builder.AddAttribute(sequence++, "value", "true");
            builder.AddContent(sequence++, "True");
            builder.CloseElement();

            builder.OpenElement(sequence++, "option");
            builder.AddAttribute(sequence++, "value", "false");
            builder.AddContent(sequence++, "False");
            builder.CloseElement();

            builder.CloseElement();
        }
        else
        {
            builder.OpenElement(sequence++, "input");

            if (property.ValueType == "integer" || property.ValueType == "decimal")
            {
                builder.AddAttribute(sequence++, "type", "number");

                if (property.ValueType == "decimal")
                {
                    builder.AddAttribute(sequence++, "step", "any");
                }

                if (property.MinValue.HasValue)
                {
                    builder.AddAttribute(sequence++, "min", property.MinValue.Value.ToString(System.Globalization.CultureInfo.InvariantCulture));
                }

                if (property.MaxValue.HasValue)
                {
                    builder.AddAttribute(sequence++, "max", property.MaxValue.Value.ToString(System.Globalization.CultureInfo.InvariantCulture));
                }
            }

            builder.AddAttribute(sequence++, "value", value);
            builder.AddAttribute(sequence++, "placeholder", placeholder);
            builder.AddAttribute(sequence++, "onchange",
                EventCallback.Factory.CreateBinder<string?>(
                    this,
                    newValue => SetValue(property.Key, newValue),
                    value));
            builder.CloseElement();
        }

        builder.OpenElement(sequence++, "button");
        builder.AddAttribute(sequence++, "type", "button");
        builder.AddAttribute(sequence++, "class", "clear-override-button");
        builder.AddAttribute(sequence++, "disabled", !isOverridden);
        builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => ClearOverride(property.Key)));
        builder.AddContent(sequence++, "Clear Override");
        builder.CloseElement();

        builder.CloseElement();
        builder.CloseElement();
    };

    private void ResetDraft()
    {
        _errors.Clear();

        if (_isEditMode && _loadedInstance is not null)
        {
            State.LoadFrom(_loadedInstance, _loadedOverrides);
            return;
        }

        State.InitializeNewDefaults();
    }

    private void GenerateSlugFromName()
    {
        if (_isEditMode)
        {
            return;
        }

        State.Slug = Slugify(State.Name);
    }

    private void GenerateRandomSeed()
    {
        if (_isEditMode)
        {
            return;
        }

        State.MapSeed = Random.Shared.Next(1, int.MaxValue);
    }

    private bool IsLocked(string fieldName)
    {
        if (!_isEditMode)
        {
            return false;
        }

        return fieldName is nameof(State.Slug)
            or nameof(State.MapSize)
            or nameof(State.MapSeed);
    }

    private string GetValue(string key)
    {
        return State.GetOverrideValue(key) ?? string.Empty;
    }

    private void SetValue(string key, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            State.RemoveOverride(key);
            return;
        }

        State.SetOverride(key, value.Trim());
    }

    private void SetBooleanValue(string key, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            State.RemoveOverride(key);
            return;
        }

        State.SetOverride(key, value.Trim().ToLowerInvariant());
    }

    private void ClearOverride(string key)
    {
        State.RemoveOverride(key);
    }

    private int GetOverrideCount(List<ServerPropertyDefinition> properties)
    {
        var count = 0;

        foreach (var property in properties)
        {
            if (State.HasOverride(property.Key))
            {
                count++;
            }
        }

        return count;
    }

    private static string Slugify(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var lower = value.Trim().ToLowerInvariant();
        var builder = new System.Text.StringBuilder();
        var previousWasDash = false;

        foreach (var ch in lower)
        {
            if (char.IsLetterOrDigit(ch))
            {
                builder.Append(ch);
                previousWasDash = false;
                continue;
            }

            if (previousWasDash)
            {
                continue;
            }

            builder.Append('-');
            previousWasDash = true;
        }

        return builder.ToString().Trim('-');
    }

    private async Task SaveInstanceAsync()
    {
        _errors.Clear();

        var validationResult = DraftValidator.Validate(State, _propertyDefinitionsByKey);
        _errors.AddRange(validationResult.Errors);

        if (_errors.Count > 0)
        {
            return;
        }

        _isSaving = true;

        try
        {
            var conflictErrors = _isEditMode
                ? await InstanceService.ValidateUpdateConflictsAsync(State)
                : await InstanceService.ValidateCreateConflictsAsync(State);

            _errors.AddRange(conflictErrors);

            if (_errors.Count > 0)
            {
                return;
            }

            if (_isEditMode)
            {
                await InstanceUpdateService.UpdateAsync(State);
            }
            else
            {
                await InstanceCreationService.CreateAsync(State);
            }

            Navigation.NavigateTo("/instances");
        }
        finally
        {
            _isSaving = false;
        }
    }
}

