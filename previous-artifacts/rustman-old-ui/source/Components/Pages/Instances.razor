@page "/instances"

@using RustMan.Models
@using RustMan.Services

@inject InstanceService InstanceService
@inject InstanceDeletionService InstanceDeletionService
@inject ISystemdService SystemdService
@inject IPlatformService PlatformService

<PageTitle>Instances</PageTitle>

<section class="page-header">
    <div>
        <p class="page-eyebrow">Instances</p>
        <h1>Server Instances</h1>
        <p class="page-copy">
            This page will become the entry point for creating, editing, and
            opening Rust server workspaces.
        </p>
    </div>

    <div class="page-actions">
        <a class="primary-link" href="/instances/create">Create Instance</a>
    </div>
</section>

<div class="instances-layout">
    <section class="surface-card">
        <h2>Instance List</h2>
        <p>
            Persisted instances will appear here with status summaries and a
            clear path into the workspace.
        </p>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <p class="instance-status">@_statusMessage</p>
        }

        <div class="instance-shell-list">
            @if (_instances.Count == 0)
            {
                <article class="instance-shell-card muted">
                    <div>
                        <h3>No instances yet</h3>
                        <p>Create an instance to begin populating this list.</p>
                    </div>
                </article>
            }
            else
            {
                @foreach (var instance in _instances)
                {
                    <article class="instance-shell-card @(instance.IsEnabled ? string.Empty : "disabled")">
                        <div>
                            <div class="instance-heading">
                                <h3>@instance.Name</h3>
                                @if (!instance.IsEnabled)
                                {
                                    <span class="instance-badge disabled">Disabled</span>
                                }
                            </div>
                            <p>@instance.Hostname</p>
                            <p class="instance-meta">
                                Slug: @instance.Slug |
                                Map: @instance.MapSize /
                                Seed: @instance.MapSeed |
                                Players: @instance.MaxPlayers
                            </p>
                        </div>

                        <div class="instance-shell-actions">
                            <a class="secondary-link" href="/instances/@instance.Slug/edit">Edit</a>
                            <a class="primary-link" href="/instances/@instance.Slug">Open Workspace</a>
                            @if (PlatformService.IsLinux() && instance.IsEnabled)
                            {
                                <button type="button"
                                        class="secondary-button"
                                        @onclick="() => StartInstanceAsync(instance)"
                                        disabled="@(_isManagingLifecycle || _isChangingAvailability || _isDeleting)">
                                    @(_isManagingLifecycle && _pendingLifecycleSlug == instance.Slug && _pendingLifecycleAction == "start" ? "Starting..." : "Start")
                                </button>
                                <button type="button"
                                        class="secondary-button"
                                        @onclick="() => StopInstanceAsync(instance)"
                                        disabled="@(_isManagingLifecycle || _isChangingAvailability || _isDeleting)">
                                    @(_isManagingLifecycle && _pendingLifecycleSlug == instance.Slug && _pendingLifecycleAction == "stop" ? "Stopping..." : "Stop")
                                </button>
                                <button type="button"
                                        class="secondary-button"
                                        @onclick="() => RestartInstanceAsync(instance)"
                                        disabled="@(_isManagingLifecycle || _isChangingAvailability || _isDeleting)">
                                    @(_isManagingLifecycle && _pendingLifecycleSlug == instance.Slug && _pendingLifecycleAction == "restart" ? "Restarting..." : "Restart")
                                </button>
                            }
                            @if (instance.IsEnabled)
                            {
                                <button type="button"
                                        class="warning-button"
                                        @onclick="() => DisableInstanceAsync(instance)"
                                        disabled="@(_isChangingAvailability || _isManagingLifecycle || _isDeleting)">
                                    @(_isChangingAvailability && _pendingAvailabilitySlug == instance.Slug ? "Disabling..." : "Disable")
                                </button>
                            }
                            else
                            {
                                <button type="button"
                                        class="success-button"
                                        @onclick="() => EnableInstanceAsync(instance)"
                                        disabled="@(_isChangingAvailability || _isManagingLifecycle || _isDeleting)">
                                    @(_isChangingAvailability && _pendingAvailabilitySlug == instance.Slug ? "Enabling..." : "Enable")
                                </button>
                            }
                            <button type="button"
                                    class="danger-button"
                                    @onclick="() => ConfirmDelete(instance.Slug)"
                                    disabled="@(_isDeleting || _isChangingAvailability || _isManagingLifecycle)">
                                Delete
                            </button>
                        </div>

                        @if (_pendingDeleteSlug == instance.Slug)
                        {
                            <div class="delete-confirmation">
                                <p>Delete <strong>@instance.Name</strong> and remove its files from disk?</p>
                                <div class="delete-confirmation-actions">
                                    <button type="button"
                                            class="danger-button"
                                            @onclick="() => DeleteInstanceAsync(instance.Slug)"
                                            disabled="@(_isDeleting || _isChangingAvailability || _isManagingLifecycle)">
                                        @(_isDeleting ? "Deleting..." : "Confirm Delete")
                                    </button>
                                    <button type="button"
                                            class="secondary-link shell-button"
                                            @onclick="CancelDelete"
                                            disabled="@(_isDeleting || _isChangingAvailability || _isManagingLifecycle)">
                                        Cancel
                                    </button>
                                </div>
                            </div>
                        }
                    </article>
                }
            }
        </div>
    </section>

    <aside class="surface-card">
        <h2>Planned Behavior</h2>
        <ul>
            <li>Create new instance</li>
            <li>Edit existing instance</li>
            <li>Open instance workspace</li>
            <li>Show high-level warnings and status</li>
        </ul>
    </aside>
</div>

@code {
    private List<InstanceRecord> _instances = new();
    private string? _pendingDeleteSlug;
    private string? _pendingAvailabilitySlug;
    private string? _pendingLifecycleSlug;
    private string? _pendingLifecycleAction;
    private string? _statusMessage;
    private bool _isDeleting;
    private bool _isChangingAvailability;
    private bool _isManagingLifecycle;

    protected override async Task OnInitializedAsync()
    {
        await LoadInstancesAsync();
    }

    private async Task LoadInstancesAsync()
    {
        _instances = await InstanceService.GetAllAsync();
    }

    private void ConfirmDelete(string slug)
    {
        _statusMessage = null;
        _pendingAvailabilitySlug = null;
        _pendingLifecycleSlug = null;
        _pendingLifecycleAction = null;
        _pendingDeleteSlug = slug;
    }

    private void CancelDelete()
    {
        _pendingDeleteSlug = null;
    }

    private async Task DeleteInstanceAsync(string slug)
    {
        _isDeleting = true;
        _statusMessage = null;

        try
        {
            await InstanceDeletionService.DeleteAsync(slug);
            _pendingDeleteSlug = null;
            _statusMessage = $"Deleted instance '{slug}'.";
            await LoadInstancesAsync();
        }
        finally
        {
            _isDeleting = false;
        }
    }

    private async Task DisableInstanceAsync(InstanceRecord instance)
    {
        _isChangingAvailability = true;
        _pendingAvailabilitySlug = instance.Slug;
        _pendingDeleteSlug = null;
        _pendingLifecycleSlug = null;
        _pendingLifecycleAction = null;
        _statusMessage = null;

        try
        {
            await InstanceService.DisableAsync(instance.Id);
            _statusMessage = $"Disabled instance '{instance.Slug}' and turned off auto start.";
            await LoadInstancesAsync();
        }
        finally
        {
            _isChangingAvailability = false;
            _pendingAvailabilitySlug = null;
        }
    }

    private async Task EnableInstanceAsync(InstanceRecord instance)
    {
        _isChangingAvailability = true;
        _pendingAvailabilitySlug = instance.Slug;
        _pendingDeleteSlug = null;
        _pendingLifecycleSlug = null;
        _pendingLifecycleAction = null;
        _statusMessage = null;

        try
        {
            await InstanceService.EnableAsync(instance.Id);
            _statusMessage = $"Enabled instance '{instance.Slug}'.";
            await LoadInstancesAsync();
        }
        finally
        {
            _isChangingAvailability = false;
            _pendingAvailabilitySlug = null;
        }
    }

    private async Task StartInstanceAsync(InstanceRecord instance)
    {
        await RunLifecycleActionAsync(
            instance,
            "start",
            () => SystemdService.StartAsync(instance.Slug),
            $"Started instance '{instance.Slug}'.");
    }

    private async Task StopInstanceAsync(InstanceRecord instance)
    {
        await RunLifecycleActionAsync(
            instance,
            "stop",
            () => SystemdService.StopAsync(instance.Slug),
            $"Stopped instance '{instance.Slug}'.");
    }

    private async Task RestartInstanceAsync(InstanceRecord instance)
    {
        await RunLifecycleActionAsync(
            instance,
            "restart",
            () => SystemdService.RestartAsync(instance.Slug),
            $"Restarted instance '{instance.Slug}'.");
    }

    private async Task RunLifecycleActionAsync(
        InstanceRecord instance,
        string action,
        Func<Task> operation,
        string successMessage)
    {
        _isManagingLifecycle = true;
        _pendingLifecycleSlug = instance.Slug;
        _pendingLifecycleAction = action;
        _pendingDeleteSlug = null;
        _pendingAvailabilitySlug = null;
        _statusMessage = null;

        try
        {
            await operation();
            _statusMessage = successMessage;
        }
        finally
        {
            _isManagingLifecycle = false;
            _pendingLifecycleSlug = null;
            _pendingLifecycleAction = null;
        }
    }
}

